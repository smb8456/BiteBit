// valid_strings_bool.bb
// Demonstrates String and Bool variables, assignments, and print.

let greeting : String = "Hello from BiteBit!";
print greeting;

let flag : Bool = true;
print flag;

// Reassign the flag
flag = false;
print flag;

// Comparison result stored as Bool
let x : Int = 10;
let y : Int = 20;
let is_greater : Bool = x > y;
print is_greater;

let is_equal : Bool = x == x;
print is_equal;
